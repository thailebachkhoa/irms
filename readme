chạy fe

cd irms/frontend
npm install
npm run dev


chạy backend IRMS

# 1. Vào thư mục backend
cd irms/backend

# 2. Cài packages
npm install

# 3. Sửa .env nếu password PostgreSQL khác "postgres"

# 4. Tạo database trong psql trước
CREATE DATABASE irms;

# 5. Tạo bảng + seed data (chạy 1 lần duy nhất)
npm run db:init

# 6. Chạy server
npm run dev

